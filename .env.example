# Kalshi API credentials
# Generate keypair locally: openssl genrsa -out kalshi.pem 2048
#                           openssl rsa -in kalshi.pem -pubout -out kalshi.pub
# Upload kalshi.pub to Kalshi -> Account -> API Keys, save the Key ID below.
KALSHI_KEY_ID=replace-me
KALSHI_PRIVATE_KEY_PATH=./kalshi.pem

# Endpoints. Uncomment ONE pair.
# Production:
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
KALSHI_REST_URL=https://api.elections.kalshi.com/trade-api/v2
# Demo (no real money, useful for first test run):
# KALSHI_WS_URL=wss://demo-api.kalshi.co/trade-api/ws/v2
# KALSHI_REST_URL=https://demo-api.kalshi.co/trade-api/v2

# Discord webhook URL (channel -> Integrations -> Webhooks -> New Webhook)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE/ME

# Filter: minimum trade notional in USD to alert on
WHALE_THRESHOLD_USD=10000

# pino log level: trace|debug|info|warn|error
LOG_LEVEL=info
